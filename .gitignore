# CyberForge - .gitignore
# Author: KAOUANE WALID

# ============================================================
# SECURITY - Never commit these
# ============================================================
*.key
*.pem
*.p12
*.pfx
*api_key*
*secret*
.env
.env.*

# Wazuh keys
/configs/agent.conf.key
/configs/*.key

# ============================================================
# Build artifacts
# ============================================================
active-response/delete_malware.exe
active-response/delete_malware.obj
*.o
*.out

# ============================================================
# OS artifacts
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Logs & scan output
# ============================================================
*.log
/scans/*.txt
/scans/*.xml
/scans/*.nmap

# ============================================================
# Editor / IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
